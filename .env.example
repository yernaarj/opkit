# ─────────────────────────────────────────────────────────
#  Скопируй этот файл в .env и заполни своими значениями
#  cp .env.example .env
# ─────────────────────────────────────────────────────────

# ── PostgreSQL ──────────────────────────────────────────
POSTGRES_USER=opkit
POSTGRES_PASSWORD=opkit_secret
POSTGRES_DB=opkit_db
POSTGRES_PORT=5433

# Prisma использует эту строку для подключения к БД
DATABASE_URL="postgresql://:@localhost:/"

# ── Redis ────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379

# ── JWT ──────────────────────────────────────────────────
# Генерируй случайный секрет: openssl rand -base64 32
JWT_SECRET=your_super_secret_key_change_me
JWT_EXPIRES_IN=7d

# ── Backend ──────────────────────────────────────────────
BACKEND_PORT=3000

# ── Frontend (Vite) ──────────────────────────────────────
VITE_API_URL=http://localhost:3000
VITE_WS_URL=http://localhost:3000

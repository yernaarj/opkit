// Prisma Schema — OpKit (Prisma 6 / CommonJS)
// Генерация клиента:  npx prisma generate
// Применить миграцию: npx prisma migrate dev --name <name>

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Хранит учётные данные; пароль хранится только в виде bcrypt-хеша
model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt      @map("updated_at")

  tasks     Task[]

  @@map("users")
}

// Задача всегда привязана к конкретному пользователю
model Task {
  id          String     @id @default(uuid())
  title       String
  description String?

  // Статусы: TODO -> IN_PROGRESS -> DONE
  status      TaskStatus @default(TODO)

  createdAt   DateTime   @default(now()) @map("created_at")
  updatedAt   DateTime   @updatedAt      @map("updated_at")

  userId      String     @map("user_id")
  user        User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("tasks")
}

enum TaskStatus {
  TODO
  IN_PROGRESS
  DONE
}

// ─────────────────────────────────────────────────────────
//  Prisma Schema — OpKit
//
//  Генерация клиента:  npx prisma generate
//  Применить миграцию: npx prisma migrate dev --name <name>
//  Просмотр БД:        npx prisma studio
// ─────────────────────────────────────────────────────────

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ── User ─────────────────────────────────────────────────
// Хранит учётные данные; пароль хранится только в виде bcrypt-хеша
model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String   // bcrypt hash, NOT plaintext

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt      @map("updated_at")

  // Один пользователь — много задач
  tasks     Task[]

  @@map("users")
}

// ── Task ─────────────────────────────────────────────────
// Задача всегда привязана к конкретному пользователю (userId)
model Task {
  id          String     @id @default(uuid())
  title       String
  description String?    // Опциональное описание

  // Статусы: TODO -> IN_PROGRESS -> DONE
  status      TaskStatus @default(TODO)

  createdAt   DateTime   @default(now()) @map("created_at")
  updatedAt   DateTime   @updatedAt      @map("updated_at")

  // Связь: задача принадлежит одному пользователю
  userId      String     @map("user_id")
  user        User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("tasks")
}

// ── TaskStatus ───────────────────────────────────────────
// Enum отражает жизненный цикл задачи
enum TaskStatus {
  TODO
  IN_PROGRESS
  DONE
}

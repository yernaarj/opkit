// Prisma Schema — OpKit (Prisma 6 / CommonJS)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt      @map("updated_at")

  tasks            Task[]   @relation("AuthorTasks")
  assignedTasks    Task[]   @relation("AssignedTasks")
  ownedBoards      Board[]  @relation("OwnedBoards")
  boardMemberships BoardMember[]

  @@map("users")
}

model Board {
  id        String   @id @default(uuid())
  name      String

  ownerId   String   @map("owner_id")
  owner     User     @relation("OwnedBoards", fields: [ownerId], references: [id], onDelete: Cascade)

  members   BoardMember[]
  tasks     Task[]
  labels    Label[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt      @map("updated_at")

  @@map("boards")
}

model BoardMember {
  boardId  String   @map("board_id")
  userId   String   @map("user_id")

  board    Board    @relation(fields: [boardId], references: [id], onDelete: Cascade)
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  joinedAt DateTime @default(now()) @map("joined_at")

  @@id([boardId, userId])
  @@map("board_members")
}

model Label {
  id      String @id @default(uuid())
  name    String
  color   String @default("#6366f1")

  boardId String @map("board_id")
  board   Board  @relation(fields: [boardId], references: [id], onDelete: Cascade)

  tasks   TaskLabel[]

  createdAt DateTime @default(now()) @map("created_at")

  @@unique([boardId, name])
  @@map("labels")
}

model TaskLabel {
  taskId  String @map("task_id")
  labelId String @map("label_id")

  task    Task   @relation(fields: [taskId], references: [id], onDelete: Cascade)
  label   Label  @relation(fields: [labelId], references: [id], onDelete: Cascade)

  @@id([taskId, labelId])
  @@map("task_labels")
}

model Task {
  id          String       @id @default(uuid())
  title       String
  description String?

  status      TaskStatus   @default(TODO)
  priority    TaskPriority @default(MEDIUM)

  // Автор задачи
  userId      String       @map("user_id")
  user        User         @relation("AuthorTasks", fields: [userId], references: [id], onDelete: Cascade)

  // Исполнитель (необязателен)
  assigneeId  String?      @map("assignee_id")
  assignee    User?        @relation("AssignedTasks", fields: [assigneeId], references: [id], onDelete: SetNull)

  boardId     String       @map("board_id")
  board       Board        @relation(fields: [boardId], references: [id], onDelete: Cascade)

  labels      TaskLabel[]

  createdAt   DateTime     @default(now()) @map("created_at")
  updatedAt   DateTime     @updatedAt      @map("updated_at")

  @@map("tasks")
}

enum TaskStatus {
  TODO
  IN_PROGRESS
  IN_REVIEW
  DONE
}

enum TaskPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}
